{
  "name": "@flink/client",
  "version": "0.1.0",
  "description": "Typed browser client for Flink site storage, uploads, realtime rooms, and AI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:types && npm run build:esm && npm run build:global",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --target=es2020 --outfile=dist/index.js",
    "build:global": "esbuild src/global.ts --bundle --format=iife --target=es2018 --outfile=dist/flink.global.js",
    "test": "node --import tsx --test src/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "20.14.2",
    "esbuild": "0.25.12",
    "tsx": "4.19.2",
    "typescript": "5.4.5"
  }
}
