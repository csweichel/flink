[Unit]
Description=Flink internal prototyping server
Documentation=https://github.com/csweichel/flink
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=flink
Group=flink
WorkingDirectory=/opt/flink
ExecStart=/opt/flink/flink-server --config /etc/flink/flink.yaml
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/flink /etc/flink /opt/flink

[Install]
WantedBy=multi-user.target
